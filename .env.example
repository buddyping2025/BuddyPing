# Supabase — get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# OneSignal — get from: onesignal.com → your app → Keys & IDs
ONESIGNAL_APP_ID=a655d68c-44cc-48aa-be39-44a7d51a6808

# Google Sign-In — get from: Firebase Console → your project → Authentication
# Use the "Web client" OAuth 2.0 Client ID (not the Android one)
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
